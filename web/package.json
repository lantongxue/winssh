{
  "name": "winssh-web",
  "private": true,
  "version": "0.1.0",
  "description": "Brand site for WinSSH.",
  "type": "module",
  "scripts": {
    "dev": "node ../node_modules/vite/bin/vite.js",
    "build": "node ../node_modules/typescript/bin/tsc --noEmit -p tsconfig.json && node ../node_modules/vite/bin/vite.js build",
    "preview": "node ../node_modules/vite/bin/vite.js preview",
    "test": "node ../node_modules/vitest/vitest.mjs run --config vitest.config.ts"
  },
  "dependencies": {
    "lucide-react": "^0.548.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
