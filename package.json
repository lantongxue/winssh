{
  "name": "winssh",
  "version": "1.1.7",
  "description": "WinSSH is a cross-platform SSH and SFTP client.",
  "main": "./out/main/index.js",
  "author": "winssh",
  "homepage": "https://github.com/example/winssh",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "test": "vitest run",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:test": "npm --prefix web run test",
    "updates:mock": "node scripts/mock-update-release.mjs",
    "updates:serve": "node scripts/update-test-server.mjs",
    "prepare": "husky",
    "commit": "cz",
    "release": "release-it",
    "postinstall": "electron-builder install-app-deps",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win nsis zip",
    "dist:mac": "npm run build && electron-builder --mac dmg zip",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "config": {
    "commitizen": {
      "path": "cz-git"
    }
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/cascadia-code": "^5.2.2",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource-variable/roboto-mono": "^5.2.8",
    "@fontsource-variable/source-code-pro": "^5.2.7",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@fontsource-variable/ubuntu-sans-mono": "^5.2.10",
    "@fontsource/cascadia-mono": "^5.2.3",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/pt-mono": "^5.2.8",
    "@fontsource/source-sans-pro": "^5.2.5",
    "@fontsource/ubuntu-mono": "^5.2.8",
    "@fontsource/vt323": "^5.2.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-image": "^0.9.0",
    "@xterm/addon-progress": "^0.2.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-fonts": "^0.1.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.1.0-beta.86",
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.548.0",
    "monaco-editor": "^0.55.1",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.72.0",
    "react-i18next": "^17.0.2",
    "react-resizable-panels": "^4.8.0",
    "react-router-dom": "^7.9.2",
    "sonner": "^2.0.7",
    "ssh2": "^1.17.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@release-it/conventional-changelog": "^11.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^5.1.1",
    "commitizen": "^4.3.1",
    "cz-git": "^1.13.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "jsdom": "^27.0.0",
    "prettier": "^3.7.4",
    "release-it": "^20.0.1",
    "shadcn": "^4.1.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^3.2.4"
  }
}
